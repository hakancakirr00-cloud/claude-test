# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.
# `.env` dosyasını ASLA git'e commit etmeyin.

# API-Football anahtarınız (api-sports.io veya RapidAPI üzerinden).
API_FOOTBALL_KEY=

# Anahtarınız RapidAPI üzerinden alındıysa true yapın, aksi halde false.
USE_RAPIDAPI=false

# Sunucu bind adresi/portu (opsiyonel).
#   127.0.0.1  -> sadece bu makinede (varsayılan, en güvenli)
#   0.0.0.0    -> yerel ağdaki diğer cihazlardan da (telefon vb.)
# BIND_HOST=127.0.0.1
# BIND_PORT=8000
