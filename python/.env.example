# Bu dosyayı `.env` olarak kopyalayın ve değerleri kendinize göre doldurun.
# `.env` dosyasını ASLA git'e commit etmeyin.

# API-Football anahtarınız (api-sports.io veya RapidAPI üzerinden).
API_FOOTBALL_KEY=

# Anahtarınız RapidAPI üzerinden alındıysa true yapın, aksi halde false.
USE_RAPIDAPI=false

# Telegram bot token'ı (BotFather'dan alınır).
TELEGRAM_BOT_TOKEN=

# Mesajların gönderileceği chat ID (kişisel veya grup/kanal).
TELEGRAM_CHAT_ID=

# true iken Telegram'a gerçek mesaj gitmez, konsola basılır.
DRY_RUN=false
